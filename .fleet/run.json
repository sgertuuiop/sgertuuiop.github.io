{
    "configurations": [
        {
            "type": "npm",
            "name": "Start dev server",
            "command": "run",
            "scripts": "dev",
        },
        {
            "type": "command",
            "name": "Sass: watch for changes",
            "program": "sass.cmd",
            "args": [
                "$PROJECT_DIR$\\styles\\src\\main.scss:.\\styles\\globals.css",
                "-w"
            ],
        },
        {
            "type": "command",
            "name": "Sass: compile",
            "program": "sass.cmd",
            "args": [
                "$PROJECT_DIR$\\styles\\src\\main.scss:.\\styles\\globals.css",
                "--style=compressed"
            ],
        },
    ]
}